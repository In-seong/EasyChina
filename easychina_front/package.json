{
  "name": "easychina_front",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev:user": "vite --config vite.user.config.ts",
    "dev:admin": "vite --config vite.admin.config.ts",
    "build:user": "vue-tsc -b && vite build --config vite.user.config.ts",
    "build:admin": "vue-tsc -b && vite build --config vite.admin.config.ts",
    "build:all": "vue-tsc -b && vite build --config vite.user.config.ts && vite build --config vite.admin.config.ts",
    "preview:user": "vite preview --config vite.user.config.ts",
    "preview:admin": "vite preview --config vite.admin.config.ts"
  },
  "dependencies": {
    "axios": "^1.13.6",
    "leaflet": "^1.9.4",
    "pinia": "^3.0.4",
    "vue": "^3.5.13",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/leaflet": "^1.9.21",
    "@vitejs/plugin-vue": "^5.2.3",
    "@vue/tsconfig": "^0.7.0",
    "autoprefixer": "^10.4.27",
    "postcss": "^8.5.8",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.8.3",
    "vite": "^6.3.5",
    "vue-tsc": "^2.2.8"
  }
}
